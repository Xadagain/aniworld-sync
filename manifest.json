{
  "manifest_version": 3,
  "name": "AniWorld List Backup",
  "version": "1.0.5",
  "description": "Backs up your watchlist and subscriptions locally as JSON.",
  "permissions": ["storage", "downloads"],
  "host_permissions": ["https://aniworld.to/*", "https://aniworld.cc/*"],
  "icons": {
    "48": "icons/backup.svg",
    "96": "icons/backup.svg"
  },
  "action": {
    "default_title": "AniWorld List Backup",
    "default_icon": "icons/backup.svg",
    "default_popup": "popup.html"
  },
  "background": {
    "scripts": ["background.js"]
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "aniworld-listen-sicherung@laurentius.local",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "content_scripts": [
    {
      "matches": ["https://aniworld.to/*", "https://aniworld.cc/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
